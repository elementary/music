#: data/music.metainfo.xml.in:10 data/music.desktop.in:6
msgid "Music"
msgstr "Музыка"

#: data/music.metainfo.xml.in:11
msgid "Queue and play local audio files"
msgstr "Жергілікті аудио файлдарды кезекке қою және ойнату"

#: data/music.metainfo.xml.in:13
msgid ""
"Quickly queue up and listen to your local music files without any extra "
"frills. See embedded album artwork. Control playback with media keys or in "
"the system audio indicator."
msgstr ""
"Жергілікті музыка файлдарыңызды артық мүмкіндіктерсіз тез кезекке қойып "
"тыңдаңыз. Енгізілген альбом өнерін қараңыз. Медиа пернелер немесе жүйелік "
"аудио индикатор арқылы ойнатуды басқарыңыз."

#: data/music.metainfo.xml.in:18 data/music.metainfo.xml.in:22
msgid "Quickly queue up your favorite tracks"
msgstr "Таңдаулы треклеріңізді тез кезекке қойыңыз"

#: data/music.metainfo.xml.in:55
msgid "elementary, Inc."
msgstr "elementary, Inc."

#: data/music.metainfo.xml.in:63 data/music.metainfo.xml.in:84
#: data/music.metainfo.xml.in:95 data/music.metainfo.xml.in:109
msgid "Improvements:"
msgstr "Жақсартулар:"

#: data/music.metainfo.xml.in:65
msgid "Show album art in the sound indicator"
msgstr "Дыбыс индикаторында альбом суретін көрсету"

#: data/music.metainfo.xml.in:66
msgid "Clear the queue"
msgstr "Кезекті тазалау"

#: data/music.metainfo.xml.in:67 data/music.metainfo.xml.in:88
#: data/music.metainfo.xml.in:98 data/music.metainfo.xml.in:131
msgid "Updated translations"
msgstr "Аудармалар жаңартылды"

#: data/music.metainfo.xml.in:86
msgid "Toolbar shows a shadow when the view is scrolled"
msgstr "Қарау айналдырылғанда құралдар тақтасы көлеңке көрсетеді"

#: data/music.metainfo.xml.in:87
msgid "Open audio files from within Music"
msgstr "Музыка ішінен аудио файлдарды ашу"

#: data/music.metainfo.xml.in:97
msgid "Open folders in the filemanager with Music"
msgstr "Музыкамен файл менеджерінде қалталарды ашу"

#: data/music.metainfo.xml.in:111
msgid "For tracks without a title, use the file name instead of the whole URI"
msgstr "Атауы жоқ треклер үшін толық URI орнына файл атауын пайдалану"

#: data/music.metainfo.xml.in:112
msgid "Skip invalid files instead of stopping playback"
msgstr "Ойнатуды тоқтатудың орнына жарамсыз файлдарды өткізіп жіберу"

#: data/music.metainfo.xml.in:113
msgid "Next and Repeat buttons always work regardless of repeat mode"
msgstr ""
"Келесі және Қайталау түймелері қайталау режиміне қарамастан әрдайым жұмыс "
"істейді"

#: data/music.metainfo.xml.in:114
msgid ""
"Now available in Catalan, Dutch, Finnish, French, German, Hebrew, Hungarian, "
"Japanese, Korean, Kurdish, Marathi, Norwegian Bokmål, Polish, Portuguese, "
"Russian, Simplified Chinese, Turkish, and Ukrainian"
msgstr ""
"Қазір каталан, голланд, фин, француз, неміс, иврит, венгр, жапон, корей, "
"күрд, маратхи, норвег бокмол, поляк, португал, орыс, жеңілдетілген қытай, "
"түрік және украин тілдерінде қол жетімді"

#: data/music.metainfo.xml.in:124
msgid "Complete rewrite"
msgstr "Толық қайта жазу"

#: data/music.metainfo.xml.in:130
msgid "Drop support for Last.FM"
msgstr "Last.FM қолдауын алып тастау"

#: data/music.desktop.in:7
msgid "Listen to music"
msgstr "Музыка тыңдау"

#: data/music.desktop.in:9
msgid "Noise;Audio;Player;MP3;Play;Playlist;Media;Songs;"
msgstr "Шу;Аудио;Ойнатқыш;MP3;Ойнату;Ойнату тізімі;Медиа;Әндер;"
